  "version": "0.0.0",
  "description": "Local-first web app for analyzing Power BI PBIP references and finding unused measures or calculated columns.",
  "license": "MIT",
  "author": "Davis Pulins",
  "type": "module",
  "scripts": {
    "dev": "vite",
